# ── Database (shared central PostGIS, read-only access) ──────────────
# Owned + migrated by NADI-mobile-app-Backend. Host is `db` because this
# service attaches to that stack's Docker network (see docker-compose.yml).
# For a non-Docker local run, use `localhost` instead of `db`.
DATABASE_URL=postgresql+asyncpg://nadi:password@db:5432/nadi_db
DATABASE_SYNC_URL=postgresql+psycopg2://nadi:password@db:5432/nadi_db

# ── Auth ─────────────────────────────────────────────────────────────
# SECRET_KEY MUST match NADI-mobile-app-Backend's SECRET_KEY so ADMIN JWTs verify.
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS (comma-separated frontend origins allowed to call this API) ──
CORS_ORIGINS=http://localhost:3000
