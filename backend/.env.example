# ── Database (shared standalone PostGIS — READ-ONLY role) ────────────
# The database is a standalone service (see the mobile repo's
# docker-compose.db.yml), owned + migrated by the mobile backend. This admin
# backend connects with the dedicated `nadi_readonly` role — it can SELECT but
# the database physically refuses any write.
# Host: `localhost` for a non-Docker local run; `host.docker.internal` from a
# container on Docker Desktop (Windows/Mac).
DATABASE_URL=postgresql+asyncpg://nadi_readonly:readonly_password@host.docker.internal:5432/nadi_db
DATABASE_SYNC_URL=postgresql+psycopg2://nadi_readonly:readonly_password@host.docker.internal:5432/nadi_db

# ── Auth (RS256 asymmetric — no shared secret with mobile; see keys/README.md) ──
# Dev defaults point at ./keys and work out of the box. The admin backend trusts
# both its own and the mobile backend's public key, so tokens from either verify.
# In production, override with secret-managed key paths (never commit prod keys).
# JWT_PRIVATE_KEY_PATH=keys/jwt_admin_private.pem
# JWT_PUBLIC_KEY_PATHS=keys/jwt_admin_public.pem,keys/jwt_mobile_public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS (comma-separated frontend origins allowed to call this API) ──
CORS_ORIGINS=http://localhost:3000
