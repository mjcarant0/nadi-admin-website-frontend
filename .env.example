# ── Database (shared central PostGIS, read-only access) ──────────────
DATABASE_URL=postgresql+asyncpg://nadi:password@localhost:5432/nadi_db
DATABASE_SYNC_URL=postgresql+psycopg2://nadi:password@localhost:5432/nadi_db

# ── Auth ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS (comma-separated frontend origins allowed to call this API) ──
CORS_ORIGINS=http://localhost:3000
